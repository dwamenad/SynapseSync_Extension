{
  "name": "google-docs-chat-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev apps/web -p 3000",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "build": "npm run build:web && npm run build:api",
    "build:web": "next build apps/web",
    "build:api": "tsc -p apps/api/tsconfig.json",
    "start": "concurrently \"npm run start:web\" \"npm run start:api\"",
    "start:web": "next start apps/web -p 3000",
    "start:api": "node apps/api/dist/server.js",
    "lint": "next lint apps/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:migrate:postgres": "prisma migrate dev --schema prisma/schema.postgres.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "next": "^15.1.4",
    "openai": "^4.78.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "19.2.13",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.1.2",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
